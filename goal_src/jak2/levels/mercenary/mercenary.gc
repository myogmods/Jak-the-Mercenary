      )
    (let ((v1-9 (entity-by-name "parking-spot-12")))
      (if v1-9
          (logior! (-> v1-9 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((v1-11 (entity-by-name "parking-spot-59")))
      (if v1-11
          (logior! (-> v1-11 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((v1-13 (entity-by-name "parking-spot-60")))
      (if v1-13
          (logior! (-> v1-13 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((v1-15 (entity-by-name "parking-spot-61")))
      (if v1-15
          (logior! (-> v1-15 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((v1-17 (entity-by-name "parking-spot-62")))
      (if v1-17
          (logior! (-> v1-17 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((gp-0 *traffic-manager*))
      (send-event gp-0 'set-alert-level 2)
      (send-event gp-0 'set-alert-duration (seconds 36000))
      (send-event gp-0 'deactivate-by-type (traffic-type crimson-guard-1))
      (send-event gp-0 'deactivate-by-type (traffic-type guard-bike))
      (send-event gp-0 'deactivate-by-type (traffic-type hellcat))
      (send-event gp-0 'deactivate-by-type (traffic-type traffic-type-20))
      (send-event gp-0 'deactivate-by-type (traffic-type bikea))
      (send-event gp-0 'deactivate-by-type (traffic-type bikeb))
      (send-event gp-0 'deactivate-by-type (traffic-type bikec))
      (send-event gp-0 'deactivate-by-type (traffic-type cara))
      (send-event gp-0 'deactivate-by-type (traffic-type carb))
      (send-event gp-0 'deactivate-by-type (traffic-type carc))
      (send-event gp-0 'set-object-target-count (traffic-type crimson-guard-1) 0)
      (send-event gp-0 'set-object-target-count (traffic-type guard-bike) 0)
      (send-event gp-0 'set-object-target-count (traffic-type hellcat) 0)
      (send-event gp-0 'set-object-target-count (traffic-type bikea) 0)
      (send-event gp-0 'set-object-target-count (traffic-type bikeb) 0)
      (send-event gp-0 'set-object-target-count (traffic-type bikec) 0)
      (send-event gp-0 'set-object-target-count (traffic-type cara) 0)
      (send-event gp-0 'set-object-target-count (traffic-type carb) 0)
      (send-event gp-0 'set-object-target-count (traffic-type carc) 0)
      (send-event gp-0 'set-object-auto-activate (traffic-type crimson-guard-1) #f)
      (send-event gp-0 'set-guard-target-count-range 0 4 4)
      (send-event gp-0 'set-guard-target-count-range 1 5 5)
      (send-event gp-0 'set-guard-target-count-range 4 0 0)
      (send-event gp-0 'set-guard-target-count-range 5 0 0)
      )
    (speech-table-set! *speech-control* (speech-type speech-type-6) (new 'static 'speech-type-info
                                                                      :channel #x1
                                                                      :priority -2
                                                                      :min-delay (seconds 2)
                                                                      :max-delay (seconds 4)
                                                                      :list (new 'static 'boxed-array :type string
                                                                        "kg320a"
                                                                        "kg321a"
                                                                        "kg322a"
                                                                        "kg323a"
                                                                        "kg324a"
                                                                        "kg325a"
                                                                        "kg326a"
                                                                        "kg327a"
                                                                        "kg328a"
                                                                        "kg329a"
                                                                        "kg330a"
                                                                        "kg331a"
                                                                        "kg332a"
                                                                        "kg333a"
                                                                        "kg334a"
                                                                        "kg335a"
                                                                        "kg336a"
                                                                        "kg337a"
                                                                        "kg338a"
                                                                        "kg339a"
                                                                        "kg340a"
                                                                        "kg341a"
                                                                        "kg342a"
                                                                        "kg343a"
                                                                        "kg344a"
                                                                        "kg345a"
                                                                        "kg347a"
                                                                        )
                                                                      )
                       )
    (dotimes (gp-1 (length *city-slums-mercenary-transport-info*))
      (set! (-> *city-slums-mercenary-transport-info* gp-1 spawned) #f)
      )
    (set! *merc-kill-count* 0)
    (set! *merc-tracking-active* #t)
    (set! (-> self data-int32 0) 0)  ;; mission transport dead completion flag
    (set! (-> self data-int32 1) 0)  ;; blocking plane spawned flag
    (set! (-> self data-int32 2) 0)  ;; first-frame init flag
    (set! (-> self data-int32 3) 0)  ;; kill count
    (set! (-> self data-int32 4) 0)  ;; prev dead guards
    (set! (-> self data-int32 6) 0)  ;; keep spawn transports flag
    (set! (-> *game-info* score) 0.0)
    (set! (-> *game-info* goal) (-> (get-game-score-ref *game-info* 8) 0))
    (set! (-> self start-time) (-> *display* game-clock frame-counter))
    (set! (-> self time-limit) (seconds 120))
    (set! (-> self slave 27)
          (ppointer->handle (process-spawn hud-timer :init hud-init-by-other :to self)))
    (set! (-> self slave 28)
          (ppointer->handle (process-spawn hud-score :init hud-init-by-other :to self)))
    (set! (-> self slave 31)
          (ppointer->handle (process-spawn hud-goal :init hud-init-by-other :to self)))
    ;; Set up stats to be consistent each time 
      (set! (-> *game-info* eco-pill-dark) 0.0)
      (set! (-> *game-info* gun-ammo 0) (-> *FACT-bank* ammo-yellow-start))
      (set! (-> *game-info* gun-ammo 1) (-> *FACT-bank* ammo-red-start))
      (set! (-> *game-info* gun-ammo 2) (-> *FACT-bank* ammo-blue-start))
      (set! (-> *game-info* gun-ammo 3) (-> *FACT-bank* ammo-dark-start))
    ;; Start gradual transition toward heavy rain
    (set! (-> *mood-control* overide-weather-flag) #f)
    (set! (-> *mood-control* target-interp cloud) 1.0)
    (set! (-> *mood-control* target-interp fog) 1.0)
    ;; Speed of 45.0, takes 45 seconds to reach full rain
    (set! (-> *mood-control* speed-interp cloud) 45.0)
    (set! (-> *mood-control* speed-interp fog) 45.0)
    ;; Prevent random weather from interrupting the transition
    (set-time-for-random-weather! *mood-control* 99999.0 99999.0)
    ;; Set up security wall
    (set! (-> self slave 30)
      (ppointer->handle
        (process-spawn security-wall
          (new 'static 'vector :x (meters 434.7774) :y (meters -1.62) :z (meters -268.0775) :w 1.0)
          (new 'static 'vector :x (meters 374.5089) :y (meters -1.62) :z (meters -273.4227) :w 1.0)
          (meters 40)
          :init security-wall-init-by-other
          :name "security-wall-slumc-mercenary"
        )
      )
    )
    ;; Reset result screen flag  
    (set! (-> self data-int32 5) 0)
    ;; Mark timer as initialized
    (set! (-> self data-int32 2) 1)
    (none)
    )
  )

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_UPDATE_HOOK
  (lambda :behavior task-manager
    ()
    ;; give everything except gun-upgrade-damage
    (logior! (-> *game-info* features) (game-feature 
      gun gun-yellow gun-red gun-blue gun-dark 
      board
      gun-upgrade-speed gun-upgrade-ammo 
      pass-red pass-green pass-yellow pass-blue 
      darkjak darkjak-bomb0 darkjak-bomb1 darkjak-invinc darkjak-giant
      ))
    (logclear! (-> *game-info* features) (game-feature gun-upgrade-damage pass-red pass-green pass-yellow))
    ;; Remove all cheats player could be using
    (logclear! (-> *game-info* secrets) (game-secrets invulnerable))
    (logclear! (-> *game-info* secrets) (game-secrets endless-dark))
    (logclear! (-> *game-info* secrets) (game-secrets endless-ammo))
    (local-vars (s5-4 object))
    ;; Once weather has fully transitioned to heavy rain, lock it with override
    (when (and (not (-> *mood-control* overide-weather-flag))
              (>= (-> *mood-control* current-interp cloud) 0.99)
              (>= (-> *mood-control* current-interp fog) 0.99)
              )
      (set! (-> *mood-control* overide-weather-flag) #t)
      (set! (-> *mood-control* overide cloud) 1.0)
      (set! (-> *mood-control* overide fog) 1.0)
      )
    ;; TIMER UPDATE (update timer every frame)
    (when (nonzero? (-> self data-int32 2))
      (let ((remaining (the-as int (- (-> self time-limit)
                                      (- (-> *display* game-clock frame-counter)
                                        (-> self start-time)
                                        )
                                      )
                      )
            )
            )
        (if (< (the-as time-frame remaining) 0)
            (set! remaining 0)
            )
        (set! (-> *game-info* timer) (the-as time-frame remaining))
        (when (zero? remaining)
          (send-event (handle->process (-> self slave 27)) 'hide-and-die)
          (send-event (handle->process (-> self slave 28)) 'hide-and-die)
          (set! (-> self data-int32 5) 1) ;; Set flag to run (merc-show-results)
          ;; (go-virtual fail)
          )
        )
      )
    ;; set current score every frame to dead guard count
    (set! (-> *game-info* score) (the float *merc-kill-count*))
    ;; Update hud-goal with highscore
    ;; game-score index 8 was unused so this is our persistent save slot
    (let ((hi-ref (get-game-score-ref *game-info* 8)))
          ;; calulate whether current score or high score is higher to show the higher.
      (if (>= (-> *game-info* score) (-> hi-ref 0))
          ;; Current run is the new best, show live score
          (set! (-> *game-info* goal) (-> *game-info* score))
          ;; Show saved highscore
          (set! (-> *game-info* goal) (-> hi-ref 0))
          )
      )
    ;; Only run transport spawning/completion when not in results screen
    (when (zero? (-> self data-int32 6))
      ;; Vanilla code to spawn transports etc
      (cond
        ((zero? (-> self data-int32 0))
         (dotimes (gp-1 (length *city-waterslums-mercenary-transport-info*))
           (let ((s5-1 (-> *city-waterslums-mercenary-transport-info* gp-1)))
             (new 'stack-no-clear 'vector)
             (new 'stack-no-clear 'vector)
             (new 'stack-no-clear 'vector)
             (new 'stack-no-clear 'vector)
             0.0
             (let ((f0-7 (vector-vector-xz-distance (target-pos 0) (-> s5-1 t-pos))))
               (cond
                 ((and (< f0-7 (meters 90)) (< (meters 50) f0-7)) ;; Converted to meters and increased max distance from 80 to 90 to spawn transports
                  (when (and (not (handle->process (-> self slave gp-1))) (< (the int (-> self data-float gp-1)) (current-time)))
                    (let ((s4-2 (new 'stack-no-clear 'transport-params)))
                      (let ((s3-2 (new 'stack-no-clear 'vector)))
                        (set! (-> s3-2 quad) (-> s5-1 t-pos quad))
                        (set! (-> s4-2 spawn-pos quad) (-> s5-1 t-pos quad))
                        (quaternion-copy! (-> s4-2 quat) (-> s5-1 t-quat))
                        (set! (-> s4-2 max-guard) (-> s5-1 num-guard))
                        (set! (-> s4-2 max-guard) (the-as uint 8))
                        (set! (-> s4-2 turret?) #t)
                        (set! (-> s4-2 speeches?) #t)
                        (set! (-> s3-2 y) 0.0)
                        )
                      (let ((a0-16 (as-type (entity-nav-mesh-by-aid (the-as actor-id 9070)) entity-nav-mesh)))
                        (when a0-16
                          (set! (-> s4-2 nav-mesh) (-> a0-16 nav-mesh))
                          (set! (-> self slave gp-1) (ppointer->handle (process-spawn transport s4-2 :to self)))
                          )
                        )
                      )
                    )
                  )
                 ((< 368640.0 f0-7)
                  (if (handle->process (-> self slave gp-1))
                      (send-event (handle->process (-> self slave gp-1)) 'leave)
                      )
                  )
                 )
               )
             )
           (if (and (handle->process (-> self slave gp-1))
                    (begin
                      (let ((s5-5 #t)
                            (a1-11 (new 'stack-no-clear 'event-message-block))
                            )
                        (set! (-> a1-11 from) (process->ppointer self))
                        (set! (-> a1-11 num-params) 0)
                        (set! (-> a1-11 message) 'guards-left)
                        (let ((v1-75 (the-as object (send-event-function (handle->process (-> self slave gp-1)) a1-11))))
                          (cmove-#f-nonzero s5-4 v1-75 s5-5)
                          )
                        )
                      s5-4
                      )
                    )
               (set! (-> self data-float gp-1) (the float (+ (current-time) (seconds 20))))
               )
           )
         )
        (else
          (let ((gp-2 0))
            (dotimes (s5-6 (length *city-waterslums-mercenary-transport-info*))
              (when (handle->process (-> self slave s5-6))
                (send-event (handle->process (-> self slave s5-6)) 'leave)
                (+! gp-2 1)
                )
              )
            (if (zero? gp-2)
                (go-virtual complete)
                )
            )
          )
        )
      )
    (none)
    )
  )

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_CODE_HOOK
  (lambda :behavior task-manager
    ()
    (when (or
            ;; Always play voice line on the very first attempt
            (zero? (-> *game-info* sub-task-list (game-task-node city-burning-bush-slumc-mercenary-resolution) death-count))
            ;; 10% chance on all subsequent attempts
            (rand-vu-percent? 0.1)
            )
      (suspend-for (seconds 3))
      (case (the int (* (rand-vu) 2.0))
        ;; "Jak: This is payback!"
        ((0) (add-process *gui-control* self (gui-channel daxter) (gui-action play) "jak066" -99.0 0))
        ;; "Daxter: We got company jak, lots of guards!"
        ((1) (add-process *gui-control* self (gui-channel daxter) (gui-action play) "ds152" -99.0 0))
        )
      )
    ;; Constantly check if the results flag is set
    (until (nonzero? (-> self data-int32 5))
      (suspend)
      )
    ;; Now run the results screen
    (merc-show-results)
    (none)
    )
  )

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_COMPLETE_HOOK
  (lambda :behavior task-manager () (none)) ;; no behavior as task cannot be completed anyway
  )

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_FAIL_HOOK
  (lambda :behavior task-manager ()
    (merc-show-results)
    ;; Ignore current continue on Triangle press after dying  
    (set-continue! *game-info* (-> self info fail-continue) #f)
    (none)
    )
  )

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_CLEANUP_HOOK
  (lambda :behavior task-manager
    ()
    (set! *merc-tracking-active* #f)
    ;; Kill points hud
    (send-event (handle->process (-> self slave 28)) 'hide-and-die)
    (let ((a0-0 *traffic-manager*))
      (send-event a0-0 'restore-default-settings)
      )
    ;; Remove security wall
    (let ((wall-proc (process-by-name "security-wall-slumc-mercenary" *active-pool*)))
      (when wall-proc
        (deactivate wall-proc)
        )
    )
    (none)
    )
  )
