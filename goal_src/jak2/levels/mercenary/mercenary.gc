;;-*-Lisp-*-
(in-package goal)

(defpartgroup group-mercenary-clock-spark
  :id 1295
  :flags (use-local-clock)
  :bounds (static-bspherem 0 0 0 5)
  :parts ((sp-item 5488 :period (seconds 1.5) :length (seconds 0.067))
    (sp-item 5488 :period (seconds 1.5) :length (seconds 0.067) :offset 200)
    (sp-item 5488 :period (seconds 1.5) :length (seconds 0.067) :offset 300)
    (sp-item 5488 :period (seconds 1.5) :length (seconds 0.067) :offset 400)
    )
  )

(defpart 5488
  :init-specs ((:texture (hotdot effects))
    (:num 8.0)
    (:x (meters 0))
    (:y (meters 0))
    (:z (meters 0))
    (:scale-x (meters 1))
    (:scale-y (meters 0.065) (meters 0.065))
    (:r 255.0)
    (:g 255.0)
    (:b 255.0)
    (:a 64.0 32.0)
    (:omega (degrees 0.045) (degrees 0.0225))
    (:vel-y (meters 0.06666667) (meters 0.13333334))
    (:accel-y (meters -0.0016666667) (meters -0.0033333334))
    (:friction 0.9 0.02)
    (:timer (seconds 0.167) (seconds 0.497))
    (:flags (sp-cpuinfo-flag-2 sp-cpuinfo-flag-3))
    (:func 'sparticle-motion-blur)
    (:next-time (seconds 0.05))
    (:conerot-x (degrees 0) (degrees 3600))
    (:conerot-y (degrees 0) (degrees 3600))
    (:rotate-y (degrees 0))
    )
  )

(deftype clock-blue-50s (process-drawable)
  ((root       collide-shape-moving :override)
   (birth-time time-frame)
   (base       vector :inline)
   (old-base   vector :inline)
   (bob-offset int64)
   (bob-amount float))
  (:methods
   (init-collision! (_type_) object))
  (:state-methods
   idle
   pickup))

(def-actor clock-blue-50s
  :bounds (0 0 0 5))

(defmethod init-collision! ((this clock-blue-50s))
  (let ((cshape (new 'process 'collide-shape-moving this (collide-list-enum hit-by-player))))
    (set! (-> cshape dynam) (copy *standard-dynamics* 'process))
    (set! (-> cshape reaction) cshape-reaction-default)
    (set! (-> cshape no-reaction) (the (function collide-shape-moving collide-query vector vector object) nothing))
    (let ((sphere (new 'process 'collide-shape-prim-sphere cshape (the-as uint 0))))
      (set! (-> sphere prim-core collide-as) (collide-spec collectable notice-blue-eco-powerup))
      (set! (-> sphere prim-core collide-with) (collide-spec jak player-list tobot))
      (set-vector! (-> sphere local-sphere) 0.0 2048.0 0.0 16384.0)
      (set! (-> cshape total-prims) (the-as uint 1))
      (set! (-> cshape root-prim) sphere)
      )
    (set! (-> cshape nav-radius) (* 0.75 (-> cshape root-prim local-sphere w)))
    (let ((prim (-> cshape root-prim)))
      (set! (-> cshape backup-collide-as) (-> prim prim-core collide-as))
      (set! (-> cshape backup-collide-with) (-> prim prim-core collide-with))
      )
    (set! (-> this root) cshape)
    )
  )

(defmethod init-from-entity! ((this clock-blue-50s) (e entity-actor))
  (logior! (-> this mask) (process-mask enemy))
  (init-collision! this)
  (process-drawable-from-entity! this e)
  (set! (-> this bob-amount) 1024.0)
  (set! (-> this bob-offset)
        (+ (the int (-> this root trans x)) (the int (-> this root trans y)) (the int (-> this root trans z))))
  (set-time! (-> this birth-time))
  (vector-copy! (-> this base) (-> this root trans))
  (vector-copy! (-> this old-base) (-> this root trans))
  (initialize-skeleton this *clock-blue-50s-sg* '())
  (set! (-> this part) (create-launch-control group-mercenary-clock-spark this))
  (logclear! (-> this mask) (process-mask actor-pause))
  (transform-post)
  (go-virtual idle :proc this)
  (none))

(defbehavior clock-blue-50s-init-by-other clock-blue-50s ((pos vector))
  (logior! (-> self mask) (process-mask enemy))
  (init-collision! self)
  (initialize-skeleton self *clock-blue-50s-sg* '())
  (set! (-> self part) (create-launch-control group-mercenary-clock-spark self))
  (vector-copy! (-> self root trans) pos)
  (quaternion-identity! (-> self root quat))
  (vector-identity! (-> self root scale))
  (set! (-> self bob-amount) 1024.0)
  (set! (-> self bob-offset)
        (+ (the int (-> self root trans x)) (the int (-> self root trans y)) (the int (-> self root trans z))))
  (set-time! (-> self birth-time))
  (vector-copy! (-> self base) (-> self root trans))
  (vector-copy! (-> self old-base) (-> self root trans))
  (logclear! (-> self mask) (process-mask actor-pause))
  (transform-post)
  (go-virtual idle))

(defstate idle (clock-blue-50s)
  :virtual #t
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (when (= (-> proc type) target)
            (go-virtual pickup)
      )
    )
  :code
    (behavior ()
      (loop
        (quaternion-rotate-y! (-> self root quat) (-> self root quat) (* (degrees 45) (seconds-per-frame)))
        (let ((bob (-> self bob-amount)))
          (when (< 0.0 bob)
                (set! (-> self root trans y)
                      (+ (-> self base y)
                        (* bob
                            (sin (* 109.22667 (the float (mod (+ (- (current-time) (-> self birth-time)) (-> self bob-offset)) (seconds 2))))))))
                (update-transforms (-> self root))))
        (suspend)
      )
    )
  :post 
    (behavior ()
      (spawn (-> self part) (-> self root trans))  ;; ADDED: spawn particles every frame
      (transform-post)
    )
)

(defstate pickup (clock-blue-50s)
  :virtual #t
  :code (behavior ()
    (let ((mgr (handle->process
                 (-> *game-info*
                     sub-task-list
                     (game-task-node city-burning-bush-slumc-mercenary-resolution)
                     info
                     manager
                     )
                 )
               )
          )
      (when mgr
        (+! (-> (the-as task-manager mgr) time-limit) (seconds 50))
        )
      )
    (sound-play "menu-pick")
    ;; Hide the actor immediately
    (logior! (-> self draw status) (draw-control-status no-draw))
    ;; Draw "+90 seconds" text for 2 seconds
    (set-time! (-> self state-time))
    (until (time-elapsed? (-> self state-time) (seconds 2))
      (let ((font (new 'stack 'font-context *font-default-matrix* 0 65 0.0 (font-color green) (font-flags shadow kerning middle))))
        (set-scale! font 0.9)
        (print-game-text "+50 seconds" font #f 44 (bucket-id progress))
        )
      (suspend)
      )
    (cleanup-for-death self)
    (deactivate self)
    )
  )

