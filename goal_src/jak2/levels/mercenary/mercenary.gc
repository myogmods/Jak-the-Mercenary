;; (define-extern crimson-guard type)
(define *merc-tracking-active* #f)
(define *merc-kill-count* 0)

(defmethod cleanup-for-death ((this crimson-guard))
  ;; zero hit-points = combat death, not a despawn/leave
  (when (and *merc-tracking-active* (zero? (-> this hit-points)))
    (+! *merc-kill-count* 1)
    (set! (-> *game-info* score) (the float *merc-kill-count*))
    )
  ;; always call through to the real cleanup so nothing else breaks
  ((method-of-type enemy cleanup-for-death) this)
  (none)
  )

(defbehavior security-wall-init-by-other security-wall ((pt0 vector) (pt1 vector) (height float))
  (set! (-> self breach) #f)
  (set! (-> self pass) 0)  ;; pass 0 never matches any pass-feature check — wall stays permanently closed
  (set! (-> self touch-count) 0)
  (set! (-> self flash) 0.0)
  (set! (-> self message) 0)
  (set! (-> self next-message-time) 0)
  ;; Set up collision shape (same as security-wall-method-22)
  (let ((s2-0 (new 'process 'collide-shape self (collide-list-enum usually-hit-by-player))))
    (let ((v1-0 (new 'process 'collide-shape-prim-mesh s2-0 (the-as uint 0) (the-as uint 0))))
      (set! (-> v1-0 prim-core collide-as) (collide-spec blocking-plane camera-blocker))
      (set! (-> v1-0 prim-core collide-with) (collide-spec jak player-list))
      (set! (-> v1-0 prim-core action) (collide-action solid))
      (set! (-> v1-0 transform-index) 3)
      (set! (-> s2-0 total-prims) (the-as uint 1))
      (set! (-> s2-0 root-prim) v1-0)
      )
    (set! (-> s2-0 nav-radius) (* 0.75 (-> s2-0 root-prim local-sphere w)))
    (let ((v1-3 (-> s2-0 root-prim)))
      (set! (-> s2-0 backup-collide-as) (-> v1-3 prim-core collide-as))
      (set! (-> s2-0 backup-collide-with) (-> v1-3 prim-core collide-with))
      )
    (set! (-> self root) s2-0)
    )
  ;; Set up transform and plane from the two endpoints (mirrors security-wall-method-22)
  (let ((mtx (new 'stack-no-clear 'matrix))
        (root (-> self root))
        )
    (vector+! (-> root trans) pt0 pt1)
    (vector-float*! (-> root trans) (-> root trans) 0.5)
    (+! (-> root trans y) (/ height 2))
    (vector-! (-> mtx vector 0) pt1 pt0)
    (let ((wall-len (vector-normalize-ret-len! (-> mtx vector 0) 1.0)))
      (set! (-> root scale x) (/ wall-len METER_LENGTH))
      (set! (-> root scale y) (/ height METER_LENGTH))
      (set! (-> root scale z) 1.0)
      (set! (-> mtx vector 1 quad) (-> (new 'static 'vector :y 1.0 :w 1.0) quad))
      (vector-cross! (-> mtx vector 2) (-> mtx vector 0) (-> mtx vector 1))
      (vector-normalize! (-> mtx vector 2) 1.0)
      (matrix->quaternion (-> root quat) mtx)
      (set! (-> self plane quad) (-> mtx vector 2 quad))
      (set! (-> self plane w) (- (vector-dot (-> mtx vector 2) (-> root trans))))
      (let ((sph (-> root root-prim local-sphere)))
        (set! (-> sph x) 0.0)
        (set! (-> sph y) (* 0.00024414062 (/ height 2)))
        (set! (-> sph z) 0.0)
        (set! (-> sph w) (* 0.5 (sqrtf (+ (* wall-len wall-len) (* height height)))))
        )
      )
    )
  ;; Load skeleton and visual setup
  (initialize-skeleton
    self
    (the-as skeleton-group (art-group-get-by-name *level* "skel-security-wall" (the-as (pointer uint32) #f)))
    (the-as pair 0)
    )
  (set! (-> self root event-self) 'touched)
  (logior! (-> self draw status) (draw-control-status disable-fog))
  (set-security-texture-masks! (the-as vector (-> self draw mgeo header texture-usage-group data 4)))
  ;; White color since pass 0 has no specific color
  (set-vector! (-> self color) 1.0 1.0 1.0 1.0)
  (set-security-color! (-> self color))
  (set-vector! (-> self draw color-mult) 1.0 1.0 1.0 1.0)
  (set-vector! (-> self draw color-emissive) 25.0 25.0 25.0 1.0)
  (transform-post)
  (go-virtual idle-close)
  (none)
  )

