(defbehavior merc-show-rules task-manager ()
  (logior! (-> *game-info* secrets) (game-secrets invulnerable))
  (until (process-grab? *target* #f) (suspend))
  (until (cpad-pressed? 0 confirm)
    (with-dma-buffer-add-bucket ((buf (-> (current-frame) global-buf))
                                (bucket-id debug-no-zbuf1)
                                )
                                (dma-buffer-add-gs-set-flusha buf (alpha-1 (new 'static 'gs-alpha :b #x1 :d #x1)) 
                                                                  (tex1-1 (new 'static 'gs-tex1 :mmag #x1 :mmin #x1))
                                )
      (let ((level-string (cond
                      ((= (level-status *level* 'ctyslumc) 'active)  "(Water Slums)")
                      ((= (level-status *level* 'ctygenc) 'active)   "(Central Plaza)")
                      ((= (level-status *level* 'ctymarkb) 'active)  "(Bazaar)")
                      ((= (level-status *level* 'stadium) 'active)   "(Forest)")
                      )
                    )
           )
      ;; Jak the Mercenary line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 75 0.0 (font-color yellow) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.8)
        (pc-encode-utf8-string (string-format "Jak the Mercenary") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Level line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 100 0.0 (font-color yellow) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.7)
        (pc-encode-utf8-string (string-format level-string) *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Destroy as many guards line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 160 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.4)
        (pc-encode-utf8-string (string-format "Destroy as many guards as you can within the time limit!") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Collect clocks line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 200 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.4)
        (pc-encode-utf8-string (string-format "Collect clock items for extra time!") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Go for high score line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 240 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.4)
        (pc-encode-utf8-string (string-format "Aim for the high-score!") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 370 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (format (clear *temp-string*) "Press ~S to start!" (lookup-text! *common-text* (text-id pad-x) #f))
        (pc-encode-utf8-string *temp-string* *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      )
    )
    (suspend)
  )
  (logclear! (-> *cpad-list* cpads 0 button0-abs 0) (pad-buttons confirm x))
  (logclear! (-> *cpad-list* cpads 0 button0-rel 0) (pad-buttons confirm x))
  (logclear! (-> *game-info* secrets) (game-secrets invulnerable))
  (until (process-release? *target*) (suspend))
  (play-sound-file "gunshot-2.wav" (the int (* (-> *setting-control* user-current sfx-volume) 30.0)))
)

(defbehavior merc-show-results task-manager ()
  ;; Kill HUDs
  (send-event (handle->process (-> self slave 27)) 'hide-and-die)
  (send-event (handle->process (-> self slave 28)) 'hide-and-die)
  (send-event (handle->process (-> self slave 31)) 'hide-and-die)
  ;; Save highscore
  (game-info-method-28 *game-info* (the-as game-score 8) (-> *game-info* score))
  ;; Despawn all transports
  (dotimes (i (length *city-slums-mercenary-transport-info*))
           (when (handle->process (-> self slave i))
                 (send-event (handle->process (-> self slave i)) 'leave)
           )
  )
  ;; Stop new transports from spawning by setting the flag to 1
  (set! (-> self data-int32 6) 1)
  ;; Lower alert level
  (send-event *traffic-manager* 'set-alert-level 0)
  ;; Make Jak "invisible" to guards 
    (when *target* (logclear! (-> *target* mask) (process-mask target)))
  ;; Compute rank
  (let* ((kills       (the int (-> *game-info* score)))
         (hi-score    (the int (-> (get-game-score-ref *game-info* 8) 0)))
         (rank-string (cond
                        ((>= kills 500) "Renegade")
                        ((>= kills 400) "Our Hero!")
                        ((>= kills 300) "Heir of Mar")
                        ((>= kills 200) "Underground Fighter")
                        ((>= kills 100) "Time Traveller")
                        ((>= kills 50)  "Brave Adventurer")
                        (else           "Villager")
                      )
         )
        )
    ;; Play jingle if this run is a new high score
    (when (>= kills hi-score)
      (play-sound-file "item-obtained.mp3" (the int (* (-> *setting-control* user-current sfx-volume) 200.0)))
      )
    (until (or (cpad-pressed? 0 confirm) (cpad-pressed? 0 triangle))
           (process-grab? *target* #f) ;; Remove control of Jak
           (with-dma-buffer-add-bucket ((buf (-> (current-frame) global-buf))
                                        (bucket-id debug-no-zbuf1)
                                       )
                                       (dma-buffer-add-gs-set-flusha buf (alpha-1 (new 'static 'gs-alpha :b #x1 :d #x1)) 
                                                                         (tex1-1 (new 'static 'gs-tex1 :mmag #x1 :mmin #x1))
                                       )
      ;; RESULT line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 50 0.0 (font-color red) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 1.8)
        (pc-encode-utf8-string (string-format "RESULT") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; High Score line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 160 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (pc-encode-utf8-string (string-format "High Score: ~D" hi-score) *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Total Points line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 210 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (pc-encode-utf8-string (string-format "Total Points: ~D" kills) *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Rank line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 260 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (pc-encode-utf8-string (string-format "Rank: ~S" rank-string) *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; Retry? line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 340 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (pc-encode-utf8-string (string-format "Retry?") *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
      ;; X = Yes, Δ = No line
      (let ((font-ctx (new 'stack 'font-context *font-default-matrix* 270 370 0.0 (font-color default) (font-flags shadow kerning middle large))))
        (set! (-> font-ctx scale) 0.6)
        (format (clear *temp-string*) "~S = Yes, ~S = No"
                (lookup-text! *common-text* (text-id pad-x) #f)
                (lookup-text! *common-text* (text-id pad-triangle) #f))
        (pc-encode-utf8-string *temp-string* *pc-encoded-temp-string*)
        (draw-string-adv *pc-encoded-temp-string* buf font-ctx)
        )
  )
    (suspend)
    )
    ;; Capture button press BEFORE releasing control
  (let ((pressed-confirm (cpad-pressed? 0 confirm)))
  ;; Clear the X button press so Jak doesn't jump when control is restored
  (logclear! (-> *cpad-list* cpads 0 button0-abs 0) (pad-buttons confirm x))
  (logclear! (-> *cpad-list* cpads 0 button0-rel 0) (pad-buttons confirm x))
  ;; Release control back to Jak
  (until (process-release? *target*)
    (suspend)
    )
  
  (if pressed-confirm
      ;; X — retry mission
      (let ((a1-0 (new 'stack-no-clear 'fail-mission-params)))
        (set! (-> a1-0 flags) (fail-mission-flags famflags-0 famflags-2))
        (set! (-> a1-0 message) (fail-mission-message fammsg-1))
        (set! (-> a1-0 retry-continue) (-> self info retry-continue))
        (set! (-> a1-0 fail-continue) (-> self info retry-continue))
        (set! (-> a1-0 reset-delay) (the-as uint 0))
        (set! (-> a1-0 task) (-> self node-info task))
        (set! (-> a1-0 fail-message) (text-id null))
        (logior! (-> a1-0 flags) (fail-mission-flags famflags-3 famflags-4 famflags-5 famflags-6))
        (start! *fail-mission-control* a1-0)
        (while (handle->process (-> *fail-mission-control* process))
          (suspend)
          )
        )
      ;; Triangle - close task node and reopen it, ending task on the spot 
      (and (task-node-close! (game-task-node city-burning-bush-slumc-mercenary-resolution))
           (task-node-open! (game-task-node city-burning-bush-slumc-mercenary-introduction))
      )
      )
    )
  )
  (none)
)

(set-subtask-hook!
  *game-info*
  (game-task-node city-burning-bush-slumc-mercenary-resolution)
  TASK_MANAGER_INIT_HOOK
  (lambda :behavior task-manager
    ()
    (case (the int (* (rand-vu) 5.0))
        ((0) (set-setting! 'music 'danger4  0.0 0)) ;; kor boss theme
        ((1) (set-setting! 'music 'danger6  0.0 0)) ;; krew boss theme
        ((2) (set-setting! 'music 'danger7  0.0 0)) ;; tomb boss theme
        ((3) (set-setting! 'music 'danger9  0.0 0)) ;; tanker ambush theme
        ((4) (set-setting! 'music 'danger11 0.0 0)) ;; fortress dump theme
        )
    (merc-show-rules)
    (set-setting! 'exclusive-task #f 0.0 (-> self node-info task))
    (set-setting! 'airlock #f 0.0 0)
    (let ((v1-5 (entity-by-name "parking-spot-1")))
      (if v1-5
          (logior! (-> v1-5 extra perm status) (entity-perm-status bit-9))
          )
      )
    (let ((v1-7 (entity-by-name "parking-spot-2")))
      (if v1-7
          (logior! (-> v1-7 extra perm status) (entity-perm-status bit-9))
