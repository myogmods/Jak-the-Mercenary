;;-*-Lisp-*-
(in-package goal)

(define-extern crimson-guard type)

(deftype merc-darkeco-barrel (process-drawable)
  ((root          collide-shape-moving :override)
   (birth-time    time-frame)
   (base          vector :inline)
   (old-base      vector :inline)
   (bob-offset    int64)
   (bob-amount    float)
   (lightning-time time-frame)
   )
  (:methods
   (init-collision! (_type_) object))
  (:state-methods
   idle
   die))

(def-actor merc-darkeco-barrel
  :bounds (0 0 0 5))

(defmethod init-collision! ((this merc-darkeco-barrel))
  (let ((cshape (new 'process 'collide-shape-moving this (collide-list-enum hit-by-player))))
    (set! (-> cshape dynam) (copy *standard-dynamics* 'process))
    (set! (-> cshape reaction) cshape-reaction-default)
    (set! (-> cshape no-reaction) (the (function collide-shape-moving collide-query vector vector object) nothing))
    (let ((mesh (new 'process 'collide-shape-prim-mesh cshape (the uint 0) (the uint 0))))
      (set! (-> mesh prim-core collide-as) (collide-spec pusher))
      (set! (-> mesh collide-with) (collide-spec jak player-list))
      (set! (-> mesh prim-core action) (collide-action solid rideable))
      (set! (-> mesh transform-index) 0)
      (set! (-> cshape total-prims) (the uint 1))
      (set! (-> cshape root-prim) mesh)
      (set-vector! (-> mesh local-sphere) 0.0 (meters 0) 0.0 (meters 5)))
    (pusher-init cshape)
    (set! (-> cshape nav-radius) (* 0.75 (-> cshape root-prim local-sphere w)))
    (let ((prim (-> cshape root-prim)))
      (set! (-> cshape backup-collide-as) (-> prim prim-core collide-as))
      (set! (-> cshape backup-collide-with) (-> prim prim-core collide-with))
      )
    (set! (-> this root) cshape))
  )

(defmethod init-from-entity! ((this merc-darkeco-barrel) (e entity-actor))
  (logior! (-> this mask) (process-mask enemy))
  (init-collision! this)
  (process-drawable-from-entity! this e)
  (set! (-> this bob-amount) 1024.0)
  (set! (-> this bob-offset)
        (+ (the int (-> this root trans x)) (the int (-> this root trans y)) (the int (-> this root trans z))))
  (set-time! (-> this birth-time))
  (vector-copy! (-> this base) (-> this root trans))
  (vector-copy! (-> this old-base) (-> this root trans))
  (initialize-skeleton this *merc-darkeco-barrel-sg* '())
  ;; (set-vector! (-> this draw color-mult) 1.0 0.0 1.0 1.0) ;; change colour 
  (set-vector! (-> this draw color-emissive) 0.25 0.25 0.25 1.0) ;; change colour
  (set! (-> this part) (create-launch-control group-darkjak-bomb this))
  (logclear! (-> this mask) (process-mask actor-pause))
  (transform-post)
  (go-virtual idle :proc this)
  (none))

(defbehavior merc-darkeco-barrel-init-by-other merc-darkeco-barrel ((pos vector))
  (logior! (-> self mask) (process-mask enemy))
  (init-collision! self)
  (initialize-skeleton self *merc-darkeco-barrel-sg* '())
  ;; (set-vector! (-> self draw color-mult) 1.0 0.0 1.0 1.0) ;; change colour 
  (set-vector! (-> self draw color-emissive) 0.25 0.25 0.25 1.0) ;; change colour
  (set! (-> self part) (create-launch-control group-darkjak-bomb self))
  (vector-copy! (-> self root trans) pos)
  (quaternion-identity! (-> self root quat))
  (vector-identity! (-> self root scale))
  (set! (-> self bob-amount) 1024.0)
  (set! (-> self bob-offset)
        (+ (the int (-> self root trans x)) (the int (-> self root trans y)) (the int (-> self root trans z))))
  (set-time! (-> self birth-time))
  (vector-copy! (-> self base) (-> self root trans))
  (vector-copy! (-> self old-base) (-> self root trans))
  (logclear! (-> self mask) (process-mask actor-pause))
  (transform-post)
  (go-virtual idle))

(defstate idle (merc-darkeco-barrel)
  :virtual #t
  :event
    (behavior ((proc process) (argc int) (message symbol) (block event-message-block))
      (case message
        (('attack)
         (go-virtual die)
         )
        (('touch)
         #t
         )
        )
      )
  :code
    (behavior ()
      (loop
        (suspend)))
        :post (behavior ()
    (transform-post)
    (when (< (-> self lightning-time) (current-time))
      (set! (-> self lightning-time)
            (+ (current-time) (the int (* 300.0 (rand-vu-float-range 0.5 1.5))))
            )
      (let ((start (new 'stack-no-clear 'vector))
            (end   (new 'stack-no-clear 'vector))
            )
        ;; Start always at the barrel's root position
        (set! (-> start quad) (-> self root trans quad))
        ;; Raycast straight down from the barrel to find the ground
        (let ((cquery (new 'stack-no-clear 'collide-query)))
          (set! (-> cquery start-pos quad) (-> start quad))
          (set-vector! (-> cquery move-dist) 0.0 (meters -40) 0.0 1.0)
          (set! (-> cquery radius) 40.96)
          (set! (-> cquery collide-with) (collide-spec backgnd))
          (set! (-> cquery ignore-process0) self)
          (set! (-> cquery ignore-process1) #f)
          (set! (-> cquery ignore-pat)
                (new 'static 'pat-surface :noentity #x1 :nojak #x1 :probe #x1 :noendlessfall #x1)
                )
          (set! (-> cquery action-mask) (collide-action solid))
          (let ((hit (fill-and-probe-using-line-sphere *collide-cache* cquery)))
            (cond
              ((>= hit 0.0)
               ;; Use exact ground hit point, then add a small random offset
               (vector+float*! end (-> cquery start-pos) (-> cquery move-dist) hit)
               (set! (-> end x) (+ (-> end x) (rand-vu-float-range -10240.0 10240.0)))
               (set! (-> end z) (+ (-> end z) (rand-vu-float-range -10240.0 10240.0)))
               )
              (else
               ;; No ground — arc to a fixed point below
               (set! (-> end quad) (-> start quad))
               (+! (-> end y) (meters -5))
               )
              )
            )
          )
        (process-spawn
          lightning-tracker
          :init lightning-tracker-init
          (-> *lightning-spec-id-table* 10)
          0
          lightning-probe-callback
          self
          start
          end
          :to self
          )
        )
      )
    )
  )

(defstate die (merc-darkeco-barrel)
  :virtual #t
  :code (behavior ()
    (sound-play "explosion")
    (let ((pos (new 'stack-no-clear 'vector)))
      (set! (-> pos quad) (-> self root trans quad))
      (part-tracker-spawn
        :to *entity-pool*
        :group group-dark-eco-box-explosion
        :mat-joint pos
        )
      (part-tracker-spawn
        :to *entity-pool*
        :group group-darkjak-bomb
        :mat-joint pos
        )
      )
    ;; Spark arc effect on Jak — multiple bolts for a powerful look
    (when *target*
      (dotimes (i 5)
        (process-drawable-shock-wall-effect
          *target*
          (-> *lightning-spec-id-table* 8)
          lightning-probe-callback
          (-> *part-id-table* 179)
          )
        (process-drawable-shock-effect
          *target*
          (-> *lightning-spec-id-table* 6)
          lightning-probe-callback
          (-> *part-id-table* 179)
          0
          0
          81920.0
          )
        )
      )
    (send-event *target* 'get-pickup (pickup-type eco-pill-dark) 100.0)
    (play-sound-file "jak3-fulldark.wav" (the int (* (-> *setting-control* user-current sfx-volume) 30.0)))
    (cleanup-for-death self)
    (deactivate self)
    )
  )

